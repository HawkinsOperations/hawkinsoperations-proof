{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proof Record Contract",
  "type": "object",
  "required": [
    "proof_id",
    "created_at",
    "detection",
    "validation",
    "outcome_summary",
    "claim_boundary"
  ],
  "properties": {
    "proof_id": { "type": "string" },
    "created_at": { "type": "string" },
    "detection": {
      "type": "object",
      "required": ["id", "repository", "commit", "artifact_paths"],
      "properties": {
        "id": { "type": "string" },
        "repository": { "type": "string" },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "repository",
        "commit",
        "validation_timestamp",
        "report_hash_sha256",
        "artifact_paths"
      ],
      "properties": {
        "repository": { "type": "string" },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "validation_timestamp": { "type": "string" },
        "report_hash_sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "outcome_summary": { "type": "string" },
    "claim_boundary": { "type": "string" }
  },
  "additionalProperties": true
}
